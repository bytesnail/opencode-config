{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "plugin": [
    "oh-my-openagent@4.16.1"
  ],
  "disabled_providers": [
    "opencode",
    "huggingface",
    "ollama-cloud"
  ],
  "provider": {
    "zhipuai-coding-plan": {
      "options": {
        "apiKey": "{file:./.secrets/ZHIPU_AI_CODING_PLAN_API_KEY}"
      }
    }
  },
  "model": "zhipuai-coding-plan/glm-5.2",
  "small_model": "kimi-for-coding/k2p7",
  "mcp": {
    "zai-mcp-server": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@z_ai/mcp-server"
      ],
      "environment": {
        "Z_AI_MODE": "ZHIPU",
        "Z_AI_API_KEY": "{file:./.secrets/ZHIPU_AI_CODING_PLAN_API_KEY}"
      }
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "{file:./.secrets/ZHIPU_AI_CODING_PLAN_BEARER_API_KEY}"
      }
    },
    "web-reader": {
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "{file:./.secrets/ZHIPU_AI_CODING_PLAN_BEARER_API_KEY}"
      }
    },
    "zread": {
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "{file:./.secrets/ZHIPU_AI_CODING_PLAN_BEARER_API_KEY}"
      }
    }
  }
}
